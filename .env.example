# ─── Serveur ──────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# URL publique de l'application (pour les liens email, redirections OAuth, etc.)
APP_URL=https://votredomaine.com

# ─── Base de données ──────────────────────────────────────────────────────────
# Priorité 1 — Supabase (recommandé en production)
SUPABASE_DATABASE_URL=postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres

# Priorité 2 — Fallback si SUPABASE_DATABASE_URL n'est pas définie
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Admin ────────────────────────────────────────────────────────────────────
# Token d'accès au panel admin (URL: /admin?token=XXX)
# Générer: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_ACCESS_TOKEN=

# Secret JWT admin — signe les sessions admin (expiration 8h)
# Générer: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ADMIN_JWT_SECRET=

# ─── SMS Provider ─────────────────────────────────────────────────────────────
# Clé API 5sim — seede automatiquement le provider en DB au premier démarrage
FIVESIM_API_KEY=

# ─── Passerelles de paiement ──────────────────────────────────────────────────
# Passerelle active : "pawapay" | "clapay" | "auto_pawapay_first" | "auto_clapay_first"
MOBILE_MONEY_GATEWAY=pawapay

# PawaPay — configurable aussi depuis Admin Panel > Paramètres
PAWAPAY_API_TOKEN=
PAWAPAY_ENV=production

# Clapay — configurable aussi depuis Admin Panel > Paramètres
CLAPAY_API_TOKEN=
CLAPAY_BASE_URL=https://api.clapay.io
CLAPAY_CALLBACK_URL=https://votredomaine.com/api/wallet/clapay/webhook
CLAPAY_RETURN_URL=https://votredomaine.com/wallet

# ─── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=
# EMAIL_FROM=Simix <noreply@votredomaine.com>

# ─── Google OAuth (optionnel) ─────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=https://votredomaine.com/api/auth/google/callback

# ─── IA (optionnel) ───────────────────────────────────────────────────────────
# OPENAI_API_KEY_DIRECT=

# ─── Stockage (optionnel) ─────────────────────────────────────────────────────
# PRIVATE_OBJECT_DIR=
# PUBLIC_OBJECT_SEARCH_PATHS=
