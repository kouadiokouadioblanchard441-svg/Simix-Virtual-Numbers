# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# Public URL of your site (used for email links, OAuth redirects, etc.)
# Example: https://simix.site  or  https://yourdomain.com
APP_URL=https://yourdomain.com

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Auth / Session ───────────────────────────────────────────────────────────
# Session secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
SESSION_SECRET=

# Admin panel access token — used in the URL to access /admin (e.g. /admin?token=XXX)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_ACCESS_TOKEN=

# Admin JWT signing secret — signs admin session tokens (8h expiry)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ADMIN_JWT_SECRET=

# Google OAuth (optional — only if Google login is enabled)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/google/callback

# ─── SMS Provider ─────────────────────────────────────────────────────────────
# 5sim API key — automatically seeds the provider in the database on first startup
FIVESIM_API_KEY=

# ─── Payment ──────────────────────────────────────────────────────────────────
# PawaPay token — also configurable from Admin Panel > Settings > PawaPay
PAWAPAY_API_TOKEN=
PAWAPAY_ENV=production

# ─── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=

# Sender address shown in emails (optional — defaults to "Simix <noreply@simix.app>")
# Example: Simix <noreply@yourdomain.com>
EMAIL_FROM=

# ─── AI (optional) ────────────────────────────────────────────────────────────
# OPENAI_API_KEY_DIRECT=
# AI_INTEGRATIONS_OPENAI_API_KEY=
# AI_INTEGRATIONS_OPENAI_BASE_URL=

# ─── Storage (optional) ───────────────────────────────────────────────────────
# PRIVATE_OBJECT_DIR=
# PUBLIC_OBJECT_SEARCH_PATHS=
