# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
LOG_LEVEL=info

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Auth / Session ───────────────────────────────────────────────────────────
# Session secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
SESSION_SECRET=

# Admin panel access token — shown in the URL to access /admin (e.g. /admin?token=XXX)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_ACCESS_TOKEN=

# Admin JWT signing secret — used to sign/verify admin session tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ADMIN_JWT_SECRET=

# Google OAuth (optional — only if Google login is enabled)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://yourdomain.com/api/auth/google/callback

# ─── SMS Provider ─────────────────────────────────────────────────────────────
# 5sim API key — auto-seeds the provider in DB on first startup
FIVESIM_API_KEY=

# ─── Payment ──────────────────────────────────────────────────────────────────
# PawaPay token — also configurable from the admin panel (Settings > PawaPay)
PAWAPAY_API_TOKEN=
PAWAPAY_ENV=production

# ─── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── AI (optional) ────────────────────────────────────────────────────────────
# OPENAI_API_KEY_DIRECT=
# AI_INTEGRATIONS_OPENAI_API_KEY=
# AI_INTEGRATIONS_OPENAI_BASE_URL=

# ─── Storage (optional) ───────────────────────────────────────────────────────
# PRIVATE_OBJECT_DIR=
# PUBLIC_OBJECT_SEARCH_PATHS=
