modules = ["nodejs-20", "web", "bash", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 3000/tcp 2>/dev/null; fuser -k 8080/tcp 2>/dev/null; cd artifacts/api-server && pnpm run build && cd ../.. && PORT=3000 NODE_ENV=development node --enable-source-maps dist/index.cjs"
waitForPort = 3000

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 5000/tcp 2>/dev/null; cd artifacts/simix && PORT=5000 pnpm run dev"
waitForPort = 5000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 23017
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "3000"
NODE_ENV = "development"
LOG_LEVEL = "info"
MOBILE_MONEY_GATEWAY = "pawapay"
PAWAPAY_ENV = "production"
ADMIN_JWT_SECRET = "6665bd40e25f791e50c6b86b9d3d6af2b9adbd0324de68188cf64e2498dc0c5bce51a3ba89899a121461d0d2c10bd1b602f8be72f9a24cee05a8b90dd19a211a"
ADMIN_ACCESS_TOKEN = "92ce33798759e51d06b36a20a2409e488c24ec6f1cda7843897e273a75d24914"
