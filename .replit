modules = ["nodejs-20", "web", "bash", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 3000/tcp 2>/dev/null; cd artifacts/api-server && pnpm run build && cd ../.. && PORT=3000 NODE_ENV=development node --enable-source-maps dist/index.cjs"
waitForPort = 3000

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "fuser -k 5000/tcp 2>/dev/null; cd artifacts/simix && PORT=5000 pnpm run dev"
waitForPort = 5000

[agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 3001
externalPort = 3003

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 23017
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PORT = "3000"
NODE_ENV = "development"
LOG_LEVEL = "info"
MOBILE_MONEY_GATEWAY = "pawapay"
PAWAPAY_ENV = "production"
ADMIN_ACCESS_TOKEN = "ab74275259fc5fcd617bd32dccdc9c6b20f8db6c2a78372d45a224a09cc0227b4129e2454bc9416350373dc59731fa27"
ADMIN_JWT_SECRET = "ed062196086b7e54f1c922c1d4e6eb2e67ca74ffe1866b551636809a393a411f5dcb19eae9071407663b1fcb733623e4eba1570fc6d04f70661b48f3570e26a2"
